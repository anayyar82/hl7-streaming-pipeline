# Local dev only — in Databricks Apps, Lakebase/warehouse vars are injected from app settings.
# Copy to .env and fill from hl7-forecasting-app/app.yaml
PGHOST=
PGDATABASE=databricks_postgres
PGPORT=5432
PGSSLMODE=require
PGUSER=
ENDPOINT_NAME=
GENIE_SPACE_ID=
DATABRICKS_WAREHOUSE_ID=
DATABRICKS_ORG_ID=
