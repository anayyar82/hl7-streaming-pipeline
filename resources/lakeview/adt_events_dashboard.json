{
  "datasets": [
    {
      "name": "ds_total_events",
      "displayName": "Total ADT Events",
      "queryLines": [
        "SELECT COUNT(*) AS total_events",
        "FROM bronze.ensemble.ens_adt",
        "WHERE event_time_stamp >= date_sub(current_date(), 365)"
      ]
    },
    {
      "name": "ds_unique_patients",
      "displayName": "Unique Patients",
      "queryLines": [
        "SELECT COUNT(DISTINCT patient_mrn) AS unique_patients",
        "FROM bronze.ensemble.ens_adt",
        "WHERE event_time_stamp >= date_sub(current_date(), 365)"
      ]
    },
    {
      "name": "ds_admissions_today",
      "displayName": "Admissions Today",
      "queryLines": [
        "SELECT COUNT(*) AS admissions_today",
        "FROM bronze.ensemble.ens_adt",
        "WHERE message_event_type = 'A01'",
        "  AND DATE(event_time_stamp) = CURRENT_DATE()"
      ]
    },
    {
      "name": "ds_event_volume",
      "displayName": "ADT Event Volume Over Time",
      "queryLines": [
        "SELECT DATE_TRUNC('day', event_time_stamp) AS event_date, COUNT(*) AS event_count",
        "FROM bronze.ensemble.ens_adt",
        "WHERE event_time_stamp >= date_sub(current_date(), 365)",
        "GROUP BY 1",
        "ORDER BY 1"
      ]
    },
    {
      "name": "ds_events_by_type",
      "displayName": "ADT Events by Event Type",
      "queryLines": [
        "SELECT message_event_type, COUNT(*) AS event_count",
        "FROM bronze.ensemble.ens_adt",
        "WHERE event_time_stamp >= date_sub(current_date(), 365)",
        "GROUP BY message_event_type",
        "ORDER BY event_count DESC"
      ]
    },
    {
      "name": "ds_patient_class",
      "displayName": "Patient Class Distribution",
      "queryLines": [
        "SELECT patient_class, COUNT(*) AS event_count",
        "FROM bronze.ensemble.ens_adt",
        "WHERE event_time_stamp >= date_sub(current_date(), 365)",
        "GROUP BY patient_class",
        "ORDER BY event_count DESC"
      ]
    },
    {
      "name": "ds_top_departments",
      "displayName": "Top 10 Departments",
      "queryLines": [
        "SELECT department, COUNT(*) AS event_count",
        "FROM bronze.ensemble.ens_adt",
        "WHERE department IS NOT NULL",
        "  AND event_time_stamp >= date_sub(current_date(), 365)",
        "GROUP BY department",
        "ORDER BY event_count DESC",
        "LIMIT 10"
      ]
    },
    {
      "name": "ds_facility_volume",
      "displayName": "Facility Volume",
      "queryLines": [
        "SELECT facility, COUNT(*) AS event_count",
        "FROM bronze.ensemble.ens_adt",
        "WHERE facility IS NOT NULL",
        "  AND event_time_stamp >= date_sub(current_date(), 365)",
        "GROUP BY facility",
        "ORDER BY event_count DESC"
      ]
    },
    {
      "name": "ds_admission_type",
      "displayName": "Admission Type Breakdown",
      "queryLines": [
        "SELECT admission_type, COUNT(*) AS event_count",
        "FROM bronze.ensemble.ens_adt",
        "WHERE admission_type IS NOT NULL",
        "  AND event_time_stamp >= date_sub(current_date(), 365)",
        "GROUP BY admission_type",
        "ORDER BY event_count DESC"
      ]
    },
    {
      "name": "ds_financial_class",
      "displayName": "Financial Class Distribution",
      "queryLines": [
        "SELECT financial_class, COUNT(*) AS event_count",
        "FROM bronze.ensemble.ens_adt",
        "WHERE financial_class IS NOT NULL",
        "  AND event_time_stamp >= date_sub(current_date(), 365)",
        "GROUP BY financial_class",
        "ORDER BY event_count DESC"
      ]
    },
    {
      "name": "ds_discharge_disposition",
      "displayName": "Discharge Disposition",
      "queryLines": [
        "SELECT discharge_diposition, COUNT(*) AS event_count",
        "FROM bronze.ensemble.ens_adt",
        "WHERE discharge_diposition IS NOT NULL",
        "  AND event_time_stamp >= date_sub(current_date(), 365)",
        "GROUP BY discharge_diposition",
        "ORDER BY event_count DESC"
      ]
    }
  ],
  "pages": [
    {
      "name": "adt_main",
      "displayName": "ADT Events Analytics",
      "layout": [
        {
          "widget": {
            "name": "w_title",
            "multilineTextboxSpec": {
              "lines": [
                "# ADT Events Analytics Dashboard\n",
                "Admit, discharge, and transfer (ADT) monitoring. Default window: **last 365 days** (set in each dataset `WHERE` — adjust as needed or replace catalog `bronze.ensemble` with your Unity Catalog path)."
              ]
            }
          },
          "position": { "x": 0, "y": 0, "width": 6, "height": 1 }
        },
        {
          "widget": {
            "name": "w_lookback_note",
            "multilineTextboxSpec": {
              "lines": [
                "##### Time range\n",
                "Charts and KPIs use a **365-day** lookback on `event_time_stamp` (except *Admissions today*). To use an interactive date filter, re-add a **date range** control in the Lakeview UI and bind a **row-level** dataset that exposes `event_time_stamp` (aggregate-only SQL breaks cross-filters).\n"
              ]
            }
          },
          "position": { "x": 0, "y": 1, "width": 6, "height": 1 }
        },
        {
          "widget": {
            "name": "w_hdr_kpis",
            "multilineTextboxSpec": {
              "lines": [
                "## Key performance indicators\n",
                "Total ADT events, distinct patients, and same-day A01 admissions."
              ]
            }
          },
          "position": { "x": 0, "y": 2, "width": 6, "height": 1 }
        },
        {
          "widget": {
            "name": "w_total_events",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_total_events",
                  "fields": [
                    { "name": "total_events", "expression": "`total_events`" }
                  ],
                  "disaggregated": true
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "total_events",
                  "displayName": "Total ADT events"
                }
              }
            }
          },
          "position": { "x": 0, "y": 3, "width": 2, "height": 1 }
        },
        {
          "widget": {
            "name": "w_unique_patients",
            "queries": [
              {
                "name": "main_query",
