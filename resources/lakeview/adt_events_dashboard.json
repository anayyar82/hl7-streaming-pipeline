                  "datasetName": "ds_unique_patients",
                  "fields": [
                    { "name": "unique_patients", "expression": "`unique_patients`" }
                  ],
                  "disaggregated": true
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "unique_patients",
