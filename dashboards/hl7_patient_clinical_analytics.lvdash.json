{
  "datasets": [
    {
      "name": "ds_age_distribution",
      "displayName": "Patient Age Distribution",
      "queryLines": [
        "SELECT CASE WHEN age < 18 THEN '0-17' WHEN age BETWEEN 18 AND 30 THEN '18-30' WHEN age BETWEEN 31 AND 45 THEN '31-45' WHEN age BETWEEN 46 AND 60 THEN '46-60' WHEN age BETWEEN 61 AND 75 THEN '61-75' ELSE '76+' END AS age_group, COUNT(*) AS patient_count FROM (SELECT *, FLOOR(DATEDIFF(CURRENT_DATE(), TO_DATE(date_of_birth, 'yyyyMMdd')) / 365.25) AS age FROM users.ankur_nayyar.gold_patient_dim WHERE date_of_birth IS NOT NULL) GROUP BY age_group ORDER BY age_group"
      ]
    },
    {
      "name": "ds_patient_city",
      "displayName": "Patients by City",
      "queryLines": [
        "SELECT address_city AS city, COUNT(*) AS patient_count FROM users.ankur_nayyar.gold_patient_dim WHERE address_city IS NOT NULL GROUP BY address_city ORDER BY patient_count DESC LIMIT 10"
      ]
    },
    {
      "name": "ds_patient_sex_encounters",
      "displayName": "Encounters by Patient Sex",
      "queryLines": [
        "SELECT p.sex, e.patient_class_desc, COUNT(*) AS encounter_count FROM users.ankur_nayyar.gold_encounter_fact e JOIN users.ankur_nayyar.gold_patient_dim p ON e.patient_id = p.patient_id GROUP BY p.sex, e.patient_class_desc ORDER BY encounter_count DESC"
      ]
    },
    {
      "name": "ds_patients_over_time",
      "displayName": "New Patients Over Time",
      "queryLines": [
        "SELECT TO_DATE(first_seen_at) AS first_seen_date, COUNT(*) AS new_patients FROM users.ankur_nayyar.gold_patient_dim GROUP BY first_seen_date ORDER BY first_seen_date"
      ]
    },
    {
      "name": "ds_patient_visit_freq",
      "displayName": "Visit Frequency per Patient",
      "queryLines": [
        "SELECT CAST(visits AS STRING) AS visits, COUNT(*) AS patient_count FROM (SELECT patient_id, COUNT(*) AS visits FROM users.ankur_nayyar.gold_encounter_fact GROUP BY patient_id) GROUP BY visits ORDER BY visits"
      ]
    },
    {
      "name": "ds_provider_workload",
      "displayName": "Provider Encounter Volume",
      "queryLines": [
        "SELECT attending_doctor_name AS provider, COUNT(*) AS total_encounters, COUNT(DISTINCT patient_id) AS unique_patients, COUNT(DISTINCT TO_DATE(created_at)) AS active_days, ROUND(COUNT(*) / COUNT(DISTINCT TO_DATE(created_at)), 1) AS avg_encounters_per_day FROM users.ankur_nayyar.gold_encounter_fact WHERE attending_doctor_name IS NOT NULL GROUP BY attending_doctor_name ORDER BY total_encounters DESC LIMIT 15"
      ]
    },
    {
      "name": "ds_provider_dept",
      "displayName": "Provider by Department",
      "queryLines": [
        "SELECT attending_doctor_name AS provider, CASE WHEN patient_class = 'E' OR UPPER(COALESCE(location_point_of_care,'')) LIKE '%ED%' OR UPPER(COALESCE(location_point_of_care,'')) LIKE '%ER%' THEN 'ED' WHEN UPPER(COALESCE(location_point_of_care,'')) LIKE '%ICU%' OR UPPER(COALESCE(location_point_of_care,'')) LIKE '%MICU%' OR UPPER(COALESCE(location_point_of_care,'')) LIKE '%SICU%' OR UPPER(COALESCE(location_point_of_care,'')) LIKE '%CCU%' THEN 'ICU' ELSE 'Other' END AS department, COUNT(*) AS encounters FROM users.ankur_nayyar.gold_encounter_fact WHERE attending_doctor_name IS NOT NULL GROUP BY provider, department ORDER BY encounters DESC LIMIT 30"
      ]
    },
    {
      "name": "ds_heart_rate",
      "displayName": "Heart Rate Distribution",
      "queryLines": [
        "SELECT CASE WHEN observation_value_numeric < 60 THEN 'Bradycardia (<60)' WHEN observation_value_numeric BETWEEN 60 AND 100 THEN 'Normal (60-100)' ELSE 'Tachycardia (>100)' END AS hr_range, COUNT(*) AS readings FROM users.ankur_nayyar.gold_observation_fact WHERE observation_id = '8867-4' AND observation_value_numeric IS NOT NULL GROUP BY hr_range"
      ]
    },
    {
      "name": "ds_bp_systolic",
      "displayName": "Systolic BP Distribution",
      "queryLines": [
        "SELECT CASE WHEN observation_value_numeric < 90 THEN 'Hypotension (<90)' WHEN observation_value_numeric BETWEEN 90 AND 120 THEN 'Normal (90-120)' WHEN observation_value_numeric BETWEEN 121 AND 140 THEN 'Elevated (121-140)' ELSE 'Hypertension (>140)' END AS bp_range, COUNT(*) AS readings FROM users.ankur_nayyar.gold_observation_fact WHERE observation_id = '8480-6' AND observation_value_numeric IS NOT NULL GROUP BY bp_range"
      ]
    },
    {
      "name": "ds_spo2",
      "displayName": "SpO2 Distribution",
      "queryLines": [
        "SELECT CASE WHEN observation_value_numeric < 90 THEN 'Critical (<90%)' WHEN observation_value_numeric BETWEEN 90 AND 94 THEN 'Low (90-94%)' ELSE 'Normal (>=95%)' END AS spo2_range, COUNT(*) AS readings FROM users.ankur_nayyar.gold_observation_fact WHERE observation_id = '59408-5' AND observation_value_numeric IS NOT NULL GROUP BY spo2_range"
      ]
    },
    {
      "name": "ds_temp_distribution",
      "displayName": "Temperature Distribution",
      "queryLines": [
        "SELECT CASE WHEN observation_value_numeric < 97.0 THEN 'Hypothermia (<97)' WHEN observation_value_numeric BETWEEN 97.0 AND 99.0 THEN 'Normal (97-99)' WHEN observation_value_numeric BETWEEN 99.1 AND 100.4 THEN 'Low Fever (99-100.4)' ELSE 'Fever (>100.4)' END AS temp_range, COUNT(*) AS readings FROM users.ankur_nayyar.gold_observation_fact WHERE observation_id = '8310-5' AND observation_value_numeric IS NOT NULL GROUP BY temp_range"
      ]
    },
    {
      "name": "ds_vital_trends",
      "displayName": "Vital Signs Over Time",
      "queryLines": [
        "SELECT TO_DATE(TO_TIMESTAMP(observation_datetime, 'yyyyMMddHHmmss')) AS obs_date, observation_text AS vital, ROUND(AVG(observation_value_numeric), 1) AS avg_value, COUNT(*) AS readings FROM users.ankur_nayyar.gold_observation_fact WHERE value_type = 'NM' AND observation_value_numeric IS NOT NULL AND observation_text IN ('HEART RATE', 'SYSTOLIC BP', 'RESPIRATORY RATE', 'SPO2') GROUP BY obs_date, vital ORDER BY obs_date"
      ]
    },
    {
      "name": "ds_lab_results",
      "displayName": "Lab Result Ranges",
      "queryLines": [
        "SELECT observation_text AS lab_test, ROUND(AVG(observation_value_numeric), 2) AS avg_value, ROUND(STDDEV(observation_value_numeric), 2) AS std_dev, ROUND(MIN(observation_value_numeric), 2) AS min_val, ROUND(PERCENTILE_APPROX(observation_value_numeric, 0.25), 2) AS p25, ROUND(PERCENTILE_APPROX(observation_value_numeric, 0.5), 2) AS median, ROUND(PERCENTILE_APPROX(observation_value_numeric, 0.75), 2) AS p75, ROUND(MAX(observation_value_numeric), 2) AS max_val, COUNT(*) AS total_results FROM users.ankur_nayyar.gold_observation_fact WHERE value_type = 'NM' AND observation_value_numeric IS NOT NULL GROUP BY observation_text ORDER BY total_results DESC"
      ]
    },
    {
      "name": "ds_diagnosis_by_dept",
      "displayName": "Top Diagnoses by Department",
      "queryLines": [
        "SELECT d.diagnosis_description, CASE WHEN e.patient_class = 'E' OR UPPER(COALESCE(e.location_point_of_care,'')) LIKE '%ED%' OR UPPER(COALESCE(e.location_point_of_care,'')) LIKE '%ER%' THEN 'ED' WHEN UPPER(COALESCE(e.location_point_of_care,'')) LIKE '%ICU%' OR UPPER(COALESCE(e.location_point_of_care,'')) LIKE '%MICU%' OR UPPER(COALESCE(e.location_point_of_care,'')) LIKE '%SICU%' OR UPPER(COALESCE(e.location_point_of_care,'')) LIKE '%CCU%' THEN 'ICU' ELSE 'Other' END AS department, COUNT(*) AS dx_count FROM users.ankur_nayyar.gold_diagnosis_fact d JOIN users.ankur_nayyar.gold_encounter_fact e ON d.message_id = e.message_id GROUP BY d.diagnosis_description, department ORDER BY dx_count DESC LIMIT 20"
      ]
    },
    {
      "name": "ds_allergy_by_patient_class",
      "displayName": "Allergies by Patient Class",
      "queryLines": [
        "SELECT a.allergen_description, e.patient_class_desc, COUNT(*) AS cnt FROM users.ankur_nayyar.gold_allergy_fact a JOIN users.ankur_nayyar.gold_encounter_fact e ON a.message_id = e.message_id GROUP BY a.allergen_description, e.patient_class_desc ORDER BY cnt DESC"
      ]
    },
    {
      "name": "ds_pipeline_funnel",
      "displayName": "Pipeline Data Funnel",
      "queryLines": [
        "SELECT 'Raw Files' AS stage, 1 AS stage_order, COUNT(*) AS record_count FROM users.ankur_nayyar.bronze_hl7_raw UNION ALL SELECT 'Split Messages', 2, COUNT(*) FROM users.ankur_nayyar.bronze_hl7_split UNION ALL SELECT 'Parsed Messages', 3, COUNT(*) FROM users.ankur_nayyar.bronze_hl7_parsed UNION ALL SELECT 'MSH Segments', 4, COUNT(*) FROM users.ankur_nayyar.silver_msh UNION ALL SELECT 'PV1 Encounters', 5, COUNT(*) FROM users.ankur_nayyar.silver_pv1 UNION ALL SELECT 'Gold Encounters', 6, COUNT(*) FROM users.ankur_nayyar.gold_encounter_fact ORDER BY stage_order"
      ]
    },
    {
      "name": "ds_observation_per_encounter",
      "displayName": "Observations per Encounter",
      "queryLines": [
        "SELECT obs_count_group, COUNT(*) AS encounter_count FROM (SELECT e.encounter_key, CASE WHEN COUNT(o.observation_key) = 0 THEN '0' WHEN COUNT(o.observation_key) BETWEEN 1 AND 3 THEN '1-3' WHEN COUNT(o.observation_key) BETWEEN 4 AND 6 THEN '4-6' ELSE '7+' END AS obs_count_group FROM users.ankur_nayyar.gold_encounter_fact e LEFT JOIN users.ankur_nayyar.gold_observation_fact o ON e.message_id = o.message_id GROUP BY e.encounter_key) GROUP BY obs_count_group ORDER BY obs_count_group"
      ]
    },
    {
      "name": "ds_location_heatmap",
      "displayName": "Encounters by Location",
      "queryLines": [
        "SELECT location_point_of_care AS unit, source_system AS facility, COUNT(*) AS encounters FROM users.ankur_nayyar.gold_encounter_fact GROUP BY unit, facility ORDER BY encounters DESC"
      ]
    }
  ],
  "pages": [
    {
