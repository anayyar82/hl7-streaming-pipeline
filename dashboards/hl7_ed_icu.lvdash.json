{
  "datasets": [
    {"name": "ds_hourly_all", "displayName": "Hourly ED+ICU", "queryLines": ["SELECT 'ED' AS department, event_hour, DATE(event_hour) AS event_date, location_facility, arrivals, discharges, net_change, hour_of_day, day_of_week, is_weekend, CASE WHEN is_weekend = 1 THEN 'Weekend' ELSE 'Weekday' END AS day_type, CASE WHEN hour_of_day BETWEEN 7 AND 18 THEN 'Day Shift' ELSE 'Night Shift' END AS shift_type FROM users.ankur_nayyar.gold_ed_hourly_census UNION ALL SELECT 'ICU', event_hour, DATE(event_hour), location_facility, arrivals, discharges, net_change, hour_of_day, day_of_week, is_weekend, CASE WHEN is_weekend = 1 THEN 'Weekend' ELSE 'Weekday' END, CASE WHEN hour_of_day BETWEEN 7 AND 18 THEN 'Day Shift' ELSE 'Night Shift' END FROM users.ankur_nayyar.gold_icu_hourly_census ORDER BY event_hour"]},
    {"name": "ds_census_total", "displayName": "Total census", "queryLines": ["SELECT SUM(estimated_census) AS total_census FROM users.ankur_nayyar.gold_department_census_current"]},
    {"name": "ds_census_ed", "displayName": "ED snapshot", "queryLines": ["SELECT SUM(estimated_census) AS ed_census, SUM(total_arrivals) AS ed_arrivals, SUM(total_discharges) AS ed_discharges FROM users.ankur_nayyar.gold_department_census_current WHERE department = 'ED'"]},
    {"name": "ds_census_icu", "displayName": "ICU snapshot", "queryLines": ["SELECT SUM(estimated_census) AS icu_census, SUM(total_arrivals) AS icu_arrivals, SUM(total_discharges) AS icu_discharges FROM users.ankur_nayyar.gold_department_census_current WHERE department = 'ICU'"]},
    {"name": "ds_census_current", "displayName": "Census by row", "queryLines": ["SELECT department, location_facility, total_arrivals, total_discharges, estimated_census, snapshot_at FROM users.ankur_nayyar.gold_department_census_current ORDER BY department, location_facility"]},
    {"name": "ds_census_pie", "displayName": "Census share", "queryLines": ["SELECT department, SUM(estimated_census) AS census FROM users.ankur_nayyar.gold_department_census_current GROUP BY department"]},
    {"name": "ds_combined_latest", "displayName": "System metrics", "queryLines": ["SELECT net_system_pressure, ROUND(ed_to_icu_ratio, 2) AS ed_to_icu_ratio, total_arrivals, total_discharges, ed_arrivals, icu_arrivals, event_hour FROM users.ankur_nayyar.gold_combined_forecast_features ORDER BY event_hour DESC LIMIT 1"]},
    {"name": "ds_ed_cumulative", "displayName": "ED cumulative", "queryLines": ["SELECT event_hour, SUM(arrivals) AS arrivals, SUM(discharges) AS discharges, SUM(net_change) AS net_change, SUM(SUM(net_change)) OVER (ORDER BY event_hour) AS cumulative_census FROM users.ankur_nayyar.gold_ed_hourly_census GROUP BY event_hour ORDER BY event_hour"]},
    {"name": "ds_icu_cumulative", "displayName": "ICU cumulative", "queryLines": ["SELECT event_hour, SUM(arrivals) AS arrivals, SUM(discharges) AS discharges, SUM(net_change) AS net_change, SUM(SUM(net_change)) OVER (ORDER BY event_hour) AS cumulative_census FROM users.ankur_nayyar.gold_icu_hourly_census GROUP BY event_hour ORDER BY event_hour"]},
    {"name": "ds_combined_pressure", "displayName": "Pressure over time", "queryLines": ["SELECT event_hour, net_system_pressure, ed_arrivals, icu_arrivals FROM users.ankur_nayyar.gold_combined_forecast_features ORDER BY event_hour"]},
    {"name": "ds_daily_all", "displayName": "Daily ED+ICU", "queryLines": ["SELECT 'ED' AS department, activity_date, location_facility, total_arrivals, total_discharges, unique_patients FROM users.ankur_nayyar.gold_ed_daily_summary UNION ALL SELECT 'ICU', activity_date, location_facility, total_arrivals, total_discharges, unique_patients FROM users.ankur_nayyar.gold_icu_daily_summary ORDER BY activity_date"]},
    {"name": "ds_hourly_pattern", "displayName": "Avg by clock hour", "queryLines": ["SELECT department, hour_of_day, ROUND(AVG(arrivals), 2) AS avg_arrivals FROM (SELECT 'ED' AS department, hour_of_day, arrivals FROM users.ankur_nayyar.gold_ed_hourly_census UNION ALL SELECT 'ICU', hour_of_day, arrivals FROM users.ankur_nayyar.gold_icu_hourly_census) t GROUP BY department, hour_of_day ORDER BY department, hour_of_day"]}
  ],
