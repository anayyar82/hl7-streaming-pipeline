        {
          "widget": { "name": "w_daily_encounters", "queries": [{ "name": "main_query", "query": { "datasetName": "ds_daily_encounters", "fields": [{ "name": "activity_date", "expression": "`activity_date`" }, { "name": "department", "expression": "`department`" }, { "name": "encounters", "expression": "`encounters`" }], "disaggregated": true } }], "spec": { "version": 3, "frame": { "title": "Daily Encounter Volume by Department", "showTitle": true }, "widgetType": "bar", "encodings": { "x": { "fieldName": "activity_date", "displayName": "Date", "scale": { "type": "temporal" } }, "y": { "fieldName": "encounters", "displayName": "Encounters", "scale": { "type": "quantitative" } }, "color": { "fieldName": "department", "displayName": "Department", "scale": { "type": "categorical" }, "legend": { "position": "top" } } } } },
