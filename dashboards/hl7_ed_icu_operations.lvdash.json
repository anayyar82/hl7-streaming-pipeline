{
  "datasets": [
    {
      "name": "ds_total_messages",
      "displayName": "Total Messages",
      "queryLines": ["SELECT COUNT(*) AS total_messages FROM users.ankur_nayyar.silver_msh"]
    },
    {
      "name": "ds_total_patients",
      "displayName": "Total Patients",
      "queryLines": ["SELECT COUNT(*) AS total_patients FROM users.ankur_nayyar.gold_patient_dim"]
    },
    {
      "name": "ds_total_encounters",
      "displayName": "Total Encounters",
      "queryLines": ["SELECT COUNT(*) AS total_encounters FROM users.ankur_nayyar.gold_encounter_fact"]
    },
    {
      "name": "ds_total_observations",
      "displayName": "Total Observations",
      "queryLines": ["SELECT COUNT(*) AS total_observations FROM users.ankur_nayyar.gold_observation_fact"]
    },
    {
      "name": "ds_total_diagnoses",
      "displayName": "Total Diagnoses",
      "queryLines": ["SELECT COUNT(*) AS total_diagnoses FROM users.ankur_nayyar.gold_diagnosis_fact"]
    },
    {
      "name": "ds_total_orders",
      "displayName": "Total Orders",
      "queryLines": ["SELECT COUNT(*) AS total_orders FROM users.ankur_nayyar.gold_order_fact"]
    },
    {
      "name": "ds_encounters_by_class",
      "displayName": "Encounters by Patient Class",
      "queryLines": ["SELECT patient_class_desc, COUNT(*) AS encounter_count FROM users.ankur_nayyar.gold_encounter_fact GROUP BY patient_class_desc ORDER BY encounter_count DESC"]
    },
    {
      "name": "ds_encounters_by_facility",
      "displayName": "Encounters by Facility",
      "queryLines": ["SELECT source_system AS facility, COUNT(*) AS encounter_count FROM users.ankur_nayyar.gold_encounter_fact GROUP BY source_system ORDER BY encounter_count DESC"]
    },
    {
      "name": "ds_encounters_by_trigger",
      "displayName": "Encounters by ADT Event",
      "queryLines": ["SELECT trigger_event, CASE trigger_event WHEN 'A01' THEN 'Admit' WHEN 'A03' THEN 'Discharge' WHEN 'A04' THEN 'Register' WHEN 'A08' THEN 'Update' ELSE trigger_event END AS event_desc, COUNT(*) AS cnt FROM users.ankur_nayyar.gold_encounter_fact GROUP BY trigger_event ORDER BY cnt DESC"]
    },
    {
      "name": "ds_messages_by_type",
      "displayName": "Messages by Type",
      "queryLines": ["SELECT message_type, sending_facility, SUM(message_count) AS total_messages FROM users.ankur_nayyar.gold_message_metrics GROUP BY message_type, sending_facility ORDER BY total_messages DESC"]
    },
    {
      "name": "ds_encounters_by_dept",
      "displayName": "Encounters by Department",
      "queryLines": ["SELECT CASE WHEN patient_class = 'E' OR UPPER(COALESCE(location_point_of_care,'')) LIKE '%ED%' OR UPPER(COALESCE(location_point_of_care,'')) LIKE '%ER%' THEN 'ED' WHEN UPPER(COALESCE(location_point_of_care,'')) LIKE '%ICU%' OR UPPER(COALESCE(location_point_of_care,'')) LIKE '%MICU%' OR UPPER(COALESCE(location_point_of_care,'')) LIKE '%SICU%' OR UPPER(COALESCE(location_point_of_care,'')) LIKE '%CCU%' THEN 'ICU' ELSE 'Other' END AS department, COUNT(*) AS encounter_count FROM users.ankur_nayyar.gold_encounter_fact GROUP BY department ORDER BY encounter_count DESC"]
    },
    {
      "name": "ds_dept_arrivals_discharges",
      "displayName": "Arrivals vs Discharges by Department",
      "queryLines": ["SELECT department, SUM(CASE WHEN trigger_event IN ('A01','A04','A02') THEN 1 ELSE 0 END) AS arrivals, SUM(CASE WHEN trigger_event = 'A03' THEN 1 ELSE 0 END) AS discharges FROM (SELECT *, CASE WHEN patient_class = 'E' OR UPPER(COALESCE(location_point_of_care,'')) LIKE '%ED%' OR UPPER(COALESCE(location_point_of_care,'')) LIKE '%ER%' THEN 'ED' WHEN UPPER(COALESCE(location_point_of_care,'')) LIKE '%ICU%' OR UPPER(COALESCE(location_point_of_care,'')) LIKE '%MICU%' OR UPPER(COALESCE(location_point_of_care,'')) LIKE '%SICU%' OR UPPER(COALESCE(location_point_of_care,'')) LIKE '%CCU%' THEN 'ICU' ELSE 'Other' END AS department FROM users.ankur_nayyar.gold_encounter_fact) GROUP BY department ORDER BY arrivals DESC"]
    },
    {
      "name": "ds_hourly_encounters",
      "displayName": "Encounters by Hour of Day",
      "queryLines": ["SELECT HOUR(TO_TIMESTAMP(admit_datetime, 'yyyyMMddHHmmss')) AS hour_of_day, CASE WHEN patient_class = 'E' OR UPPER(COALESCE(location_point_of_care,'')) LIKE '%ED%' OR UPPER(COALESCE(location_point_of_care,'')) LIKE '%ER%' THEN 'ED' WHEN UPPER(COALESCE(location_point_of_care,'')) LIKE '%ICU%' OR UPPER(COALESCE(location_point_of_care,'')) LIKE '%MICU%' OR UPPER(COALESCE(location_point_of_care,'')) LIKE '%SICU%' OR UPPER(COALESCE(location_point_of_care,'')) LIKE '%CCU%' THEN 'ICU' ELSE 'Other' END AS department, COUNT(*) AS encounters FROM users.ankur_nayyar.gold_encounter_fact WHERE admit_datetime IS NOT NULL GROUP BY hour_of_day, department ORDER BY hour_of_day"]
    },
    {
      "name": "ds_daily_encounters",
      "displayName": "Daily Encounter Volume",
      "queryLines": ["SELECT TO_DATE(TO_TIMESTAMP(admit_datetime, 'yyyyMMddHHmmss')) AS activity_date, CASE WHEN patient_class = 'E' OR UPPER(COALESCE(location_point_of_care,'')) LIKE '%ED%' OR UPPER(COALESCE(location_point_of_care,'')) LIKE '%ER%' THEN 'ED' WHEN UPPER(COALESCE(location_point_of_care,'')) LIKE '%ICU%' OR UPPER(COALESCE(location_point_of_care,'')) LIKE '%MICU%' OR UPPER(COALESCE(location_point_of_care,'')) LIKE '%SICU%' OR UPPER(COALESCE(location_point_of_care,'')) LIKE '%CCU%' THEN 'ICU' ELSE 'Other' END AS department, COUNT(*) AS encounters FROM users.ankur_nayyar.gold_encounter_fact WHERE admit_datetime IS NOT NULL GROUP BY activity_date, department ORDER BY activity_date"]
    },
    {
      "name": "ds_top_diagnoses",
      "displayName": "Top 15 Diagnoses",
      "queryLines": ["SELECT diagnosis_code, diagnosis_description, COUNT(*) AS diagnosis_count FROM users.ankur_nayyar.gold_diagnosis_fact GROUP BY diagnosis_code, diagnosis_description ORDER BY diagnosis_count DESC LIMIT 15"]
    },
    {
      "name": "ds_top_providers",
      "displayName": "Top 10 Attending Providers",
      "queryLines": ["SELECT attending_doctor_name AS provider, COUNT(*) AS encounter_count FROM users.ankur_nayyar.gold_encounter_fact WHERE attending_doctor_name IS NOT NULL GROUP BY attending_doctor_name ORDER BY encounter_count DESC LIMIT 10"]
    },
    {
      "name": "ds_daily_arrivals_discharges",
      "displayName": "Daily Arrivals vs Discharges",
      "queryLines": ["SELECT TO_DATE(TO_TIMESTAMP(admit_datetime, 'yyyyMMddHHmmss')) AS activity_date, SUM(CASE WHEN trigger_event IN ('A01','A04') THEN 1 ELSE 0 END) AS arrivals, SUM(CASE WHEN trigger_event = 'A03' THEN 1 ELSE 0 END) AS discharges FROM users.ankur_nayyar.gold_encounter_fact WHERE admit_datetime IS NOT NULL GROUP BY activity_date ORDER BY activity_date"]
    },
    {
      "name": "ds_census_current",
      "displayName": "Current Department Census",
      "queryLines": ["SELECT department, location_facility, total_arrivals, total_discharges, estimated_census FROM users.ankur_nayyar.gold_department_census_current ORDER BY department"]
    },
    {
      "name": "ds_forecast_latest",
      "displayName": "Latest Forecasts",
      "queryLines": ["SELECT model_name, department, target_metric, forecast_horizon_hours, target_hour, ROUND(predicted_value, 1) AS predicted, ROUND(prediction_lower_bound, 1) AS lower_bound, ROUND(prediction_upper_bound, 1) AS upper_bound, ROUND(confidence_level * 100, 0) AS confidence_pct, ROUND(actual_value, 1) AS actual, ROUND(absolute_error, 2) AS error FROM users.ankur_nayyar.gold_forecast_predictions WHERE forecast_generated_at = (SELECT MAX(forecast_generated_at) FROM users.ankur_nayyar.gold_forecast_predictions) ORDER BY department, target_metric, forecast_horizon_hours"]
    },
    {
      "name": "ds_forecast_accuracy",
      "displayName": "Model Accuracy Over Time",
      "queryLines": ["SELECT prediction_date, model_name, department, target_metric, mae, mape, prediction_count FROM users.ankur_nayyar.gold_forecast_accuracy ORDER BY prediction_date DESC LIMIT 100"]
    },
    {
      "name": "ds_forecast_vs_actual",
      "displayName": "Predicted vs Actual",
      "queryLines": ["SELECT target_hour, department, target_metric, predicted_value, actual_value, absolute_error, forecast_horizon_hours FROM users.ankur_nayyar.gold_forecast_predictions WHERE actual_value IS NOT NULL AND forecast_horizon_hours = 1 ORDER BY target_hour DESC LIMIT 200"]
    },
    {
      "name": "ds_model_metadata",
      "displayName": "Model Training Summary",
      "queryLines": ["SELECT model_name, model_version, ROUND(rmse, 3) AS rmse, ROUND(r2_score, 3) AS r2_score, ROUND(mae, 3) AS mae, best_trial_description, training_timestamp FROM users.ankur_nayyar.gold_model_training_metadata ORDER BY model_name"]
    }
  ],
  "pages": [
