{
  "datasets": [
    {
      "name": "ds_total_messages",
      "displayName": "Total Messages",
      "query": "SELECT COUNT(*) AS total_messages FROM users.ankur_nayyar.silver_msh"
    },
    {
      "name": "ds_total_patients",
      "displayName": "Total Patients",
      "query": "SELECT COUNT(*) AS total_patients FROM users.ankur_nayyar.gold_patient_dim"
    },
    {
      "name": "ds_total_encounters",
      "displayName": "Total Encounters",
      "query": "SELECT COUNT(*) AS total_encounters FROM users.ankur_nayyar.gold_encounter_fact"
    },
    {
      "name": "ds_total_observations",
      "displayName": "Total Observations",
      "query": "SELECT COUNT(*) AS total_observations FROM users.ankur_nayyar.gold_observation_fact"
    },
    {
      "name": "ds_total_diagnoses",
      "displayName": "Total Diagnoses",
      "query": "SELECT COUNT(*) AS total_diagnoses FROM users.ankur_nayyar.gold_diagnosis_fact"
    },
    {
      "name": "ds_total_orders",
      "displayName": "Total Orders",
      "query": "SELECT COUNT(*) AS total_orders FROM users.ankur_nayyar.gold_order_fact"
    },
    {
      "name": "ds_encounters_by_class",
      "displayName": "Encounters by Patient Class",
      "query": "SELECT patient_class_desc, COUNT(*) AS encounter_count FROM users.ankur_nayyar.gold_encounter_fact GROUP BY patient_class_desc ORDER BY encounter_count DESC"
    },
    {
      "name": "ds_encounters_by_facility",
      "displayName": "Encounters by Facility",
      "query": "SELECT source_system AS facility, COUNT(*) AS encounter_count FROM users.ankur_nayyar.gold_encounter_fact GROUP BY source_system ORDER BY encounter_count DESC"
    },
    {
      "name": "ds_encounters_by_trigger",
      "displayName": "Encounters by ADT Event",
      "query": "SELECT trigger_event, CASE trigger_event WHEN 'A01' THEN 'Admit' WHEN 'A03' THEN 'Discharge' WHEN 'A04' THEN 'Register' WHEN 'A08' THEN 'Update' ELSE trigger_event END AS event_desc, COUNT(*) AS cnt FROM users.ankur_nayyar.gold_encounter_fact GROUP BY trigger_event ORDER BY cnt DESC"
    },
    {
      "name": "ds_messages_by_type",
      "displayName": "Messages by Type",
      "query": "SELECT message_type, sending_facility, SUM(message_count) AS total_messages FROM users.ankur_nayyar.gold_message_metrics GROUP BY message_type, sending_facility ORDER BY total_messages DESC"
    },
    {
      "name": "ds_encounters_by_dept",
      "displayName": "Encounters by Department",
      "query": "SELECT CASE WHEN patient_class = 'E' OR UPPER(COALESCE(location_point_of_care,'')) LIKE '%ED%' OR UPPER(COALESCE(location_point_of_care,'')) LIKE '%ER%' THEN 'ED' WHEN UPPER(COALESCE(location_point_of_care,'')) LIKE '%ICU%' OR UPPER(COALESCE(location_point_of_care,'')) LIKE '%MICU%' OR UPPER(COALESCE(location_point_of_care,'')) LIKE '%SICU%' OR UPPER(COALESCE(location_point_of_care,'')) LIKE '%CCU%' THEN 'ICU' ELSE 'Other' END AS department, COUNT(*) AS encounter_count FROM users.ankur_nayyar.gold_encounter_fact GROUP BY department ORDER BY encounter_count DESC"
    },
    {
      "name": "ds_dept_arrivals_discharges",
      "displayName": "Arrivals vs Discharges by Department",
      "query": "SELECT department, SUM(CASE WHEN trigger_event IN ('A01','A04','A02') THEN 1 ELSE 0 END) AS arrivals, SUM(CASE WHEN trigger_event = 'A03' THEN 1 ELSE 0 END) AS discharges FROM (SELECT *, CASE WHEN patient_class = 'E' OR UPPER(COALESCE(location_point_of_care,'')) LIKE '%ED%' OR UPPER(COALESCE(location_point_of_care,'')) LIKE '%ER%' THEN 'ED' WHEN UPPER(COALESCE(location_point_of_care,'')) LIKE '%ICU%' OR UPPER(COALESCE(location_point_of_care,'')) LIKE '%MICU%' OR UPPER(COALESCE(location_point_of_care,'')) LIKE '%SICU%' OR UPPER(COALESCE(location_point_of_care,'')) LIKE '%CCU%' THEN 'ICU' ELSE 'Other' END AS department FROM users.ankur_nayyar.gold_encounter_fact) GROUP BY department ORDER BY arrivals DESC"
    },
    {
      "name": "ds_hourly_encounters",
      "displayName": "Encounters by Hour of Day",
      "query": "SELECT HOUR(TO_TIMESTAMP(admit_datetime, 'yyyyMMddHHmmss')) AS hour_of_day, CASE WHEN patient_class = 'E' OR UPPER(COALESCE(location_point_of_care,'')) LIKE '%ED%' OR UPPER(COALESCE(location_point_of_care,'')) LIKE '%ER%' THEN 'ED' WHEN UPPER(COALESCE(location_point_of_care,'')) LIKE '%ICU%' OR UPPER(COALESCE(location_point_of_care,'')) LIKE '%MICU%' OR UPPER(COALESCE(location_point_of_care,'')) LIKE '%SICU%' OR UPPER(COALESCE(location_point_of_care,'')) LIKE '%CCU%' THEN 'ICU' ELSE 'Other' END AS department, COUNT(*) AS encounters FROM users.ankur_nayyar.gold_encounter_fact WHERE admit_datetime IS NOT NULL GROUP BY hour_of_day, department ORDER BY hour_of_day"
    },
    {
      "name": "ds_daily_encounters",
      "displayName": "Daily Encounter Volume",
      "query": "SELECT TO_DATE(TO_TIMESTAMP(admit_datetime, 'yyyyMMddHHmmss')) AS activity_date, CASE WHEN patient_class = 'E' OR UPPER(COALESCE(location_point_of_care,'')) LIKE '%ED%' OR UPPER(COALESCE(location_point_of_care,'')) LIKE '%ER%' THEN 'ED' WHEN UPPER(COALESCE(location_point_of_care,'')) LIKE '%ICU%' OR UPPER(COALESCE(location_point_of_care,'')) LIKE '%MICU%' OR UPPER(COALESCE(location_point_of_care,'')) LIKE '%SICU%' OR UPPER(COALESCE(location_point_of_care,'')) LIKE '%CCU%' THEN 'ICU' ELSE 'Other' END AS department, COUNT(*) AS encounters FROM users.ankur_nayyar.gold_encounter_fact WHERE admit_datetime IS NOT NULL GROUP BY activity_date, department ORDER BY activity_date"
    },
    {
      "name": "ds_patient_sex",
      "displayName": "Patients by Sex",
      "query": "SELECT sex, COUNT(*) AS patient_count FROM users.ankur_nayyar.gold_patient_dim GROUP BY sex ORDER BY patient_count DESC"
    },
    {
      "name": "ds_top_diagnoses",
      "displayName": "Top 15 Diagnoses",
      "query": "SELECT diagnosis_code, diagnosis_description, COUNT(*) AS diagnosis_count FROM users.ankur_nayyar.gold_diagnosis_fact GROUP BY diagnosis_code, diagnosis_description ORDER BY diagnosis_count DESC LIMIT 15"
    },
    {
      "name": "ds_allergens",
      "displayName": "Allergen Distribution",
      "query": "SELECT allergen_description, severity_text, is_severe, COUNT(*) AS allergy_count FROM users.ankur_nayyar.gold_allergy_fact GROUP BY allergen_description, severity_text, is_severe ORDER BY allergy_count DESC"
    },
    {
      "name": "ds_allergy_severity",
      "displayName": "Allergy Severity Breakdown",
      "query": "SELECT severity_text, COUNT(*) AS cnt FROM users.ankur_nayyar.gold_allergy_fact GROUP BY severity_text ORDER BY cnt DESC"
    },
    {
      "name": "ds_top_vitals",
      "displayName": "Vital Sign Averages",
      "query": "SELECT observation_text AS vital_sign, ROUND(AVG(observation_value_numeric), 1) AS avg_value, ROUND(MIN(observation_value_numeric), 1) AS min_value, ROUND(MAX(observation_value_numeric), 1) AS max_value, COUNT(*) AS reading_count FROM users.ankur_nayyar.gold_observation_fact WHERE value_type = 'NM' AND observation_value_numeric IS NOT NULL GROUP BY observation_text ORDER BY reading_count DESC"
    },
    {
      "name": "ds_abnormal_results",
      "displayName": "Abnormal vs Normal Results",
      "query": "SELECT CASE WHEN is_abnormal THEN 'Abnormal' ELSE 'Normal' END AS result_status, COUNT(*) AS cnt FROM users.ankur_nayyar.gold_observation_fact GROUP BY result_status"
    },
    {
      "name": "ds_top_providers",
      "displayName": "Top 10 Attending Providers",
      "query": "SELECT attending_doctor_name AS provider, COUNT(*) AS encounter_count FROM users.ankur_nayyar.gold_encounter_fact WHERE attending_doctor_name IS NOT NULL GROUP BY attending_doctor_name ORDER BY encounter_count DESC LIMIT 10"
    },
    {
      "name": "ds_lab_orders",
      "displayName": "Lab Orders by Test",
      "query": "SELECT universal_service_text AS test_name, COUNT(*) AS order_count FROM users.ankur_nayyar.gold_order_fact GROUP BY universal_service_text ORDER BY order_count DESC LIMIT 10"
    },
    {
      "name": "ds_census_current",
      "displayName": "Current Department Census",
      "query": "SELECT department, location_facility, total_arrivals, total_discharges, estimated_census FROM users.ankur_nayyar.gold_department_census_current ORDER BY department"
    },
    {
      "name": "ds_daily_arrivals_discharges",
      "displayName": "Daily Arrivals vs Discharges",
      "query": "SELECT TO_DATE(TO_TIMESTAMP(admit_datetime, 'yyyyMMddHHmmss')) AS activity_date, SUM(CASE WHEN trigger_event IN ('A01','A04') THEN 1 ELSE 0 END) AS arrivals, SUM(CASE WHEN trigger_event = 'A03' THEN 1 ELSE 0 END) AS discharges FROM users.ankur_nayyar.gold_encounter_fact WHERE admit_datetime IS NOT NULL GROUP BY activity_date ORDER BY activity_date"
    }
  ],
  "pages": [
